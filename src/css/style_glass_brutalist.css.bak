/* ============================================================
   GLASSMORPHISM + SWISS BRUTALIST FUSION
   Bold type. Frosted glass. Raw structure.
   ============================================================ */

/* --- Variables & Reset --- */
:root {
    --bg: #0c0c0e;
    --bg-2: #141416;
    --bg-3: #1a1a1e;
    --surface: rgba(255, 255, 255, 0.04);
    --glass: rgba(255, 255, 255, 0.06);
    --glass-border: rgba(255, 255, 255, 0.08);
    --glass-hover: rgba(255, 255, 255, 0.1);
    --glass-strong: rgba(255, 255, 255, 0.12);
    --text: #f0f0f0;
    --text-2: rgba(255, 255, 255, 0.7);
    --text-3: rgba(255, 255, 255, 0.4);
    --text-muted: rgba(255, 255, 255, 0.25);
    --accent: #ff2d2d;
    --accent-soft: rgba(255, 45, 45, 0.15);
    --accent-glow: rgba(255, 45, 45, 0.3);
    --green: #22c55e;
    --green-soft: rgba(34, 197, 94, 0.15);
    --yellow: #eab308;
    --yellow-soft: rgba(234, 179, 8, 0.15);
    --blue: #3b82f6;
    --blue-soft: rgba(59, 130, 246, 0.15);
    --orange: #f97316;
    --orange-soft: rgba(249, 115, 22, 0.15);
    --white: #ffffff;
    --font: 'Inter', 'Helvetica Neue', Arial, system-ui, sans-serif;
    --mono: 'JetBrains Mono', 'Fira Code', monospace;
    --blur: blur(20px) saturate(180%);
    --blur-heavy: blur(40px) saturate(200%);
    --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-slow: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    font-size: 16px;
}

body {
    font-family: var(--font);
    line-height: 1.7;
    color: var(--text-2);
    background: var(--bg);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

a {
    color: var(--accent);
    text-decoration: none;
    transition: var(--transition);
}

a:hover {
    color: var(--white);
}

img {
    max-width: 100%;
    height: auto;
}

::selection {
    background: var(--accent);
    color: var(--white);
}

/* --- Scroll Progress --- */
.scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    background: var(--accent);
    z-index: 10000;
    transition: width 0.1s linear;
}

/* --- Back to Top --- */
.back-to-top {
    position: fixed;
    bottom: 32px;
    right: 32px;
    width: 52px;
    height: 52px;
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    color: var(--text);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: var(--transition);
    z-index: 999;
}

.back-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}

.back-to-top:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--white);
}

.back-to-top svg {
    width: 20px;
    height: 20px;
}

/* --- Lucide Icons --- */
svg[class*="lucide"] {
    width: 1em;
    height: 1em;
    stroke-width: 2;
    vertical-align: middle;
    display: inline-block;
    line-height: 1;
}

i[data-lucide] svg {
    vertical-align: -0.125em;
}

/* --- Layout --- */
.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
}

.section {
    padding: 120px 0;
    position: relative;
}

.section-alt {
    background: var(--bg-2);
}

.section-title {
    font-size: 3rem;
    font-weight: 900;
    color: var(--text);
    margin-bottom: 12px;
    text-align: left;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1.1;
}

.section-title i {
    color: var(--accent);
    margin-right: 16px;
}

.section-title i svg {
    width: 36px;
    height: 36px;
    vertical-align: -0.15em;
}

.section-title::after {
    content: '';
    display: block;
    width: 80px;
    height: 4px;
    background: var(--accent);
    margin: 24px 0 56px;
}

/* ============================================================
   NAVBAR — Floating glass bar
   ============================================================ */
.navbar {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    max-width: 1200px;
    z-index: 1000;
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    padding: 0 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    transition: var(--transition);
    border: 1px solid var(--glass-border);
    border-radius: 0;
}

.navbar.scrolled {
    background: rgba(12, 12, 14, 0.9);
    border-color: rgba(255, 255, 255, 0.06);
    top: 0;
    width: 100%;
    max-width: 100%;
    border-radius: 0;
    border-left: none;
    border-right: none;
    border-top: none;
}

.nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.nav-brand i {
    color: var(--accent);
}

.nav-brand i svg {
    width: 22px;
    height: 22px;
}

.nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 8px;
    transition: var(--transition);
}

.nav-toggle:hover {
    color: var(--accent);
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 2px;
}

.nav-links a {
    color: var(--text-3);
    padding: 10px 16px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: var(--transition);
    border: 1px solid transparent;
}

.nav-links a i svg {
    width: 14px;
    height: 14px;
}

.nav-links a:hover {
    color: var(--text);
    background: var(--glass);
    border-color: var(--glass-border);
}

.nav-links a.active {
    color: var(--white);
    background: var(--accent);
    border-color: var(--accent);
}

/* ============================================================
   HERO — Bold typographic statement
   ============================================================ */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse 80% 60% at 20% 40%, rgba(255, 45, 45, 0.06) 0%, transparent 70%),
        radial-gradient(ellipse 60% 50% at 80% 60%, rgba(59, 130, 246, 0.04) 0%, transparent 70%);
}

.hero-overlay {
    position: absolute;
    inset: 0;
    background-image: 
        linear-gradient(var(--glass-border) 1px, transparent 1px),
        linear-gradient(90deg, var(--glass-border) 1px, transparent 1px);
    background-size: 80px 80px;
    opacity: 0.3;
}

.hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.25;
}

.hero-orb-1 {
    width: 500px;
    height: 500px;
    background: var(--accent);
    top: 5%;
    left: -10%;
    animation: orbFloat 12s ease-in-out infinite;
}

.hero-orb-2 {
    width: 350px;
    height: 350px;
    background: var(--blue);
    bottom: 10%;
    right: -5%;
    animation: orbFloat 16s ease-in-out infinite reverse;
}

.hero-orb-3 {
    width: 200px;
    height: 200px;
    background: var(--yellow);
    top: 60%;
    left: 40%;
    animation: orbFloat 10s ease-in-out infinite;
}

@keyframes orbFloat {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(30px, -20px); }
    50% { transform: translate(-20px, 30px); }
    75% { transform: translate(20px, 20px); }
}

.hero-content {
    position: relative;
    text-align: left;
    padding: 40px 24px;
    max-width: 1200px;
    width: 100%;
    z-index: 2;
}

.hero h1 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    color: var(--text);
    margin-bottom: 24px;
    line-height: 1.05;
    letter-spacing: -0.04em;
    text-transform: uppercase;
}

.hero h1 i {
    color: var(--accent);
}

.hero h1 i svg {
    width: 0.8em;
    height: 0.8em;
}

.hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-3);
    margin-bottom: 56px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 3px;
    max-width: 600px;
}

.hero-stats {
    display: flex;
    gap: 0;
    margin-bottom: 56px;
}

.stat-item {
    text-align: left;
    padding: 24px 40px;
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-right: none;
    position: relative;
}

.stat-item:last-child {
    border-right: 1px solid var(--glass-border);
}

.stat-item::after {
    display: none;
}

.stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 900;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.03em;
}

.stat-label {
    display: block;
    font-size: 0.7rem;
    color: var(--text-3);
    margin-top: 8px;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
}

.hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--accent);
    color: var(--white);
    padding: 18px 40px;
    border-radius: 0;
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.hero-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s ease;
}

.hero-btn:hover::before {
    left: 100%;
}

.hero-btn i svg {
    width: 18px;
    height: 18px;
}

.hero-btn:hover {
    background: var(--white);
    color: var(--bg);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(255, 45, 45, 0.3);
}

/* ============================================================
   PAGE HEADER (non-index pages)
   ============================================================ */
.page-header {
    background: var(--bg);
    padding: 160px 24px 80px;
    text-align: left;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--glass-border);
}

.page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse at 0% 100%, rgba(255, 45, 45, 0.06), transparent 50%),
        linear-gradient(var(--glass-border) 1px, transparent 1px),
        linear-gradient(90deg, var(--glass-border) 1px, transparent 1px);
    background-size: 100% 100%, 80px 80px, 80px 80px;
}

.page-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    color: var(--text);
    margin-bottom: 12px;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    position: relative;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 24px;
}

.page-header h1 i {
    color: var(--accent);
    margin-right: 16px;
}

.page-header p {
    font-size: 1rem;
    color: var(--text-3);
    position: relative;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 24px;
}

/* ============================================================
   INTRODUCTION
   ============================================================ */
.intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: start;
}

.intro-text p {
    margin-bottom: 24px;
    font-size: 1.05rem;
    color: var(--text-2);
    line-height: 1.9;
}

.intro-text strong {
    color: var(--text);
}

.intro-text em {
    color: var(--accent);
    font-style: normal;
    font-weight: 600;
}

.intro-highlights {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.highlight-card {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-left: 4px solid var(--accent);
    padding: 24px 28px;
    border-radius: 0;
    transition: var(--transition);
    position: relative;
}

.highlight-card::after {
    display: none;
}

.highlight-card:hover {
    background: var(--glass-hover);
    border-left-color: var(--white);
    transform: translateX(8px);
}

.highlight-card i {
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 10px;
}

.highlight-card i svg {
    width: 28px;
    height: 28px;
}

.highlight-card h4 {
    color: var(--text);
    margin-bottom: 8px;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 1px;
}

.highlight-card p {
    font-size: 0.9rem;
    color: var(--text-3);
    line-height: 1.6;
}

/* ============================================================
   TIMELINE
   ============================================================ */
.timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 50px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--accent), var(--glass-border), var(--accent));
}

.timeline-item {
    display: flex;
    align-items: flex-start;
    gap: 28px;
    margin-bottom: 28px;
    position: relative;
}

.timeline-marker {
    flex-shrink: 0;
    width: 100px;
    height: 40px;
    background: var(--accent);
    color: var(--white);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 900;
    z-index: 1;
    letter-spacing: 1px;
    font-variant-numeric: tabular-nums;
}

.timeline-content {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    padding: 24px 28px;
    border-radius: 0;
    flex: 1;
    transition: var(--transition);
}

.timeline-content::before {
    display: none;
}

.timeline-content:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
    transform: translateX(6px);
}

.timeline-content h4 {
    color: var(--text);
    margin-bottom: 8px;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
}

.timeline-content h4 i {
    color: var(--accent);
    margin-right: 8px;
}

.timeline-content h4 i svg {
    width: 18px;
    height: 18px;
    vertical-align: -0.15em;
}

.timeline-content p {
    font-size: 0.9rem;
    color: var(--text-3);
    line-height: 1.7;
}

/* ============================================================
   DEVICE CARDS — Glass panels
   ============================================================ */
.devices-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2px;
}

.device-card {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 36px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.device-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 0;
    background: var(--accent);
    transition: height 0.4s ease;
}

.device-card::after {
    display: none;
}

.device-card:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
}

.device-card:hover::before {
    height: 100%;
}

.device-icon {
    width: 56px;
    height: 56px;
    background: var(--accent-soft);
    border: 1px solid rgba(255, 45, 45, 0.2);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: var(--transition);
}

.device-card:hover .device-icon {
    background: var(--accent);
    border-color: var(--accent);
}

.device-card:hover .device-icon i {
    color: var(--white);
}

.device-icon i {
    font-size: 1.5rem;
    color: var(--accent);
    transition: var(--transition);
}

.device-icon i svg {
    width: 26px;
    height: 26px;
}

.device-card h3 {
    font-size: 1.2rem;
    color: var(--text);
    margin-bottom: 20px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.device-specs {
    margin-bottom: 20px;
}

.spec {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid var(--glass-border);
    font-size: 0.88rem;
    transition: var(--transition);
    color: var(--text-2);
}

.spec:hover {
    padding-left: 6px;
    color: var(--text);
}

.spec-label {
    color: var(--text-3);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
}

.device-desc {
    font-size: 0.88rem;
    color: var(--text-3);
    margin-bottom: 20px;
    line-height: 1.7;
}

.device-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.tag {
    padding: 6px 16px;
    border-radius: 0;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.tag-green {
    background: var(--green-soft);
    color: var(--green);
    border: 1px solid rgba(34, 197, 94, 0.2);
}

.tag-yellow {
    background: var(--yellow-soft);
    color: var(--yellow);
    border: 1px solid rgba(234, 179, 8, 0.2);
}

.tag-red {
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid rgba(255, 45, 45, 0.2);
}

/* ============================================================
   DATA TABLE
   ============================================================ */
.interfaces-table-wrapper,
.table-responsive {
    overflow-x: auto;
    border: 1px solid var(--glass-border);
}

.data-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--glass);
    font-size: 0.9rem;
}

.data-table thead {
    background: var(--glass-strong);
}

.data-table th {
    padding: 16px 20px;
    text-align: left;
    font-weight: 800;
    white-space: nowrap;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text);
    border-bottom: 2px solid var(--accent);
}

.data-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--glass-border);
    color: var(--text-2);
    transition: var(--transition);
}

.data-table tbody tr {
    transition: var(--transition);
}

.data-table tbody tr:hover {
    background: var(--glass-hover);
}

.data-table tbody tr:last-child td {
    border-bottom: none;
}

.data-table td i {
    color: var(--accent);
    margin-right: 8px;
}

.table-check {
    color: var(--green) !important;
}

.table-cross {
    color: var(--accent) !important;
}

.table-partial {
    color: var(--yellow) !important;
}

/* ============================================================
   FILE SYSTEMS
   ============================================================ */
.fs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2px;
}

.fs-card {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 28px 24px;
    text-align: center;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.fs-card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.fs-card:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
}

.fs-card:hover::before {
    transform: scaleX(1);
}

.fs-card h4 {
    font-size: 1.4rem;
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.fs-bar {
    height: 4px;
    background: var(--glass-strong);
    margin-bottom: 18px;
    overflow: hidden;
}

.fs-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--orange));
    font-size: 0;
    transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.fs-card ul {
    list-style: none;
    text-align: left;
    margin-bottom: 16px;
}

.fs-card ul li {
    font-size: 0.82rem;
    color: var(--text-3);
    padding: 5px 0;
    border-bottom: 1px dotted var(--glass-border);
}

.fs-card ul li:last-child {
    border-bottom: none;
}

.fs-card ul li strong {
    color: var(--text);
}

.fs-verdict {
    display: inline-block;
    padding: 5px 18px;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}

.verdict-good {
    background: var(--green-soft);
    color: var(--green);
    border: 1px solid rgba(34, 197, 94, 0.2);
}

.verdict-warning {
    background: var(--yellow-soft);
    color: var(--yellow);
    border: 1px solid rgba(234, 179, 8, 0.2);
}

/* ============================================================
   RISK CARDS
   ============================================================ */
.risks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2px;
}

.risk-card {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border-radius: 0;
    padding: 32px;
    position: relative;
    overflow: hidden;
    transition: var(--transition);
    border: 1px solid var(--glass-border);
}

.risk-card:hover {
    background: var(--glass-hover);
}

.risk-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
}

.risk-card:hover::before {
    width: 6px;
}

.risk-critical::before { background: var(--accent); }
.risk-high::before { background: var(--orange); }
.risk-medium::before { background: var(--yellow); }
.risk-low::before { background: var(--green); }

.risk-level {
    display: inline-block;
    padding: 4px 14px;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 2px;
    margin-bottom: 14px;
    text-transform: uppercase;
}

.risk-critical .risk-level { background: var(--accent-soft); color: var(--accent); border: 1px solid rgba(255,45,45,0.2); }
.risk-high .risk-level { background: var(--orange-soft); color: var(--orange); border: 1px solid rgba(249,115,22,0.2); }
.risk-medium .risk-level { background: var(--yellow-soft); color: var(--yellow); border: 1px solid rgba(234,179,8,0.2); }
.risk-low .risk-level { background: var(--green-soft); color: var(--green); border: 1px solid rgba(34,197,94,0.2); }

.risk-card h4 {
    color: var(--text);
    margin-bottom: 12px;
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.risk-card h4 i {
    margin-right: 8px;
    color: var(--accent);
}

.risk-card h4 i svg {
    width: 18px;
    height: 18px;
    vertical-align: -0.15em;
}

.risk-card p {
    font-size: 0.88rem;
    color: var(--text-3);
    margin-bottom: 16px;
    line-height: 1.7;
}

.risk-card p strong {
    color: var(--text);
}

.risk-meta {
    display: flex;
    gap: 24px;
    font-size: 0.78rem;
    color: var(--text-muted);
    padding-top: 14px;
    border-top: 1px solid var(--glass-border);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.risk-meta strong {
    color: var(--text-2);
}

/* ============================================================
   PROTECTION / ENCRYPTION
   ============================================================ */
.protection-block {
    margin-bottom: 80px;
}

.protection-block h3 {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 32px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.protection-block h3 i {
    color: var(--accent);
    margin-right: 12px;
}

.encryption-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2px;
}

.encrypt-card {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 36px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.encrypt-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 0;
    background: var(--accent);
    transition: height 0.3s ease;
}

.encrypt-card:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
}

.encrypt-card:hover::after {
    height: 3px;
}

.encrypt-logo {
    width: 52px;
    height: 52px;
    background: var(--accent-soft);
    border: 1px solid rgba(255, 45, 45, 0.2);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: var(--transition);
}

.encrypt-card:hover .encrypt-logo {
    background: var(--accent);
    border-color: var(--accent);
}

.encrypt-card:hover .encrypt-logo i {
    color: var(--white);
}

.encrypt-logo i {
    font-size: 1.3rem;
    color: var(--accent);
    transition: var(--transition);
}

.encrypt-logo i svg {
    width: 24px;
    height: 24px;
}

.encrypt-card h4 {
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.encrypt-card ul {
    list-style: none;
}

.encrypt-card ul li {
    font-size: 0.88rem;
    color: var(--text-3);
    padding: 6px 0;
    padding-left: 22px;
    position: relative;
    line-height: 1.5;
}

.encrypt-card ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 800;
}

/* Backup Visual */
.backup-visual {
    display: flex;
    justify-content: center;
    gap: 2px;
    margin-bottom: 40px;
}

.backup-rule {
    text-align: center;
    flex: 1;
    max-width: 220px;
}

.backup-number {
    width: 100px;
    height: 100px;
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 2px solid var(--accent);
    color: var(--accent);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.8rem;
    font-weight: 900;
    margin: 0 auto 16px;
    transition: var(--transition);
    position: relative;
}

.backup-number::after {
    display: none;
}

.backup-rule:hover .backup-number {
    background: var(--accent);
    color: var(--white);
    transform: scale(1.05);
}

.backup-rule p {
    font-size: 0.85rem;
    color: var(--text-2);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.backup-types {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2px;
}

.backup-type {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 28px;
    transition: var(--transition);
}

.backup-type:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
}

.backup-type h5 {
    color: var(--text);
    margin-bottom: 10px;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
}

.backup-type h5 i {
    color: var(--accent);
    margin-right: 8px;
}

.backup-type p {
    font-size: 0.88rem;
    color: var(--text-3);
    line-height: 1.6;
}

/* Checklist */
.checklist {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.checklist-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 24px;
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.checklist-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent);
    transform: scaleY(0);
    transition: transform 0.3s ease;
}

.checklist-item:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
    transform: translateX(6px);
}

.checklist-item:hover::before {
    transform: scaleY(1);
}

.check-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: var(--accent-soft);
    border: 1px solid rgba(255, 45, 45, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
}

.check-icon i {
    color: var(--accent);
}

.check-icon i svg {
    width: 18px;
    height: 18px;
}

.check-content {
    flex: 1;
    font-size: 0.92rem;
    color: var(--text-2);
}

.check-content strong {
    color: var(--text);
    font-weight: 800;
}

.nist-badge {
    flex-shrink: 0;
    padding: 4px 12px;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 2px;
    text-transform: uppercase;
}

.badge-identify { background: var(--blue-soft); color: var(--blue); border: 1px solid rgba(59,130,246,0.2); }
.badge-protect { background: var(--green-soft); color: var(--green); border: 1px solid rgba(34,197,94,0.2); }
.badge-detect { background: var(--yellow-soft); color: var(--yellow); border: 1px solid rgba(234,179,8,0.2); }
.badge-respond { background: var(--orange-soft); color: var(--orange); border: 1px solid rgba(249,115,22,0.2); }
.badge-recover { background: var(--accent-soft); color: var(--accent); border: 1px solid rgba(255,45,45,0.2); }

/* ============================================================
   CASE STUDIES
   ============================================================ */
.cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2px;
}

.case-card {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    overflow: hidden;
    transition: var(--transition);
}

.case-card:hover {
    border-color: var(--accent);
}

.case-header {
    padding: 24px 28px;
    color: var(--white);
    position: relative;
    overflow: hidden;
}

.case-header::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 60%);
}

.case-danger { background: linear-gradient(135deg, #991b1b, #dc2626); }
.case-warning { background: linear-gradient(135deg, #c2410c, #ea580c); }
.case-success { background: linear-gradient(135deg, #166534, #16a34a); }

.case-year {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(10px);
    padding: 3px 16px;
    font-size: 0.72rem;
    font-weight: 900;
    margin-bottom: 8px;
    letter-spacing: 1px;
}

.case-header h4 {
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.95rem;
    letter-spacing: 0.5px;
}

.case-body {
    padding: 28px;
}

.case-body p {
    font-size: 0.9rem;
    color: var(--text-3);
    margin-bottom: 18px;
    line-height: 1.7;
}

.case-body p strong {
    color: var(--text);
}

.case-lesson {
    background: var(--surface);
    padding: 16px 20px;
    font-size: 0.85rem;
    color: var(--text-2);
    border-left: 3px solid var(--accent);
    line-height: 1.7;
}

.case-lesson strong {
    color: var(--text);
}

/* ============================================================
   CTA SECTION
   ============================================================ */
.cta-section {
    background: var(--bg);
    text-align: center;
    padding: 100px 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
}

.cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(255, 45, 45, 0.04), transparent 60%);
}

.cta-content {
    position: relative;
    z-index: 1;
}

.cta-content h2 {
    font-size: 2.5rem;
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
}

.cta-content h2 i {
    color: var(--accent);
}

.cta-content h2 i svg {
    width: 36px;
    height: 36px;
    vertical-align: -0.15em;
}

.cta-content p {
    color: var(--text-3);
    margin-bottom: 36px;
    font-size: 1rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--accent);
    color: var(--white);
    padding: 16px 36px;
    border-radius: 0;
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    border: none;
    cursor: pointer;
    transition: var(--transition);
}

.btn-primary::before {
    display: none;
}

.btn-primary:hover::before {
    display: none;
}

.btn-primary:hover {
    background: var(--white);
    color: var(--bg);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px var(--accent-glow);
}

/* ============================================================
   CHARTS PAGE
   ============================================================ */
.chart-wrapper {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 36px;
    max-width: 900px;
    margin: 0 auto;
    transition: var(--transition);
}

.chart-wrapper:hover {
    border-color: rgba(255, 255, 255, 0.15);
}

.chart-wrapper-sm {
    max-width: 700px;
}

.chart-description {
    text-align: left;
    color: var(--text-3);
    max-width: 700px;
    margin: -20px auto 28px;
    font-size: 0.92rem;
    line-height: 1.7;
}

/* Risk Legend */
.risk-legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 24px;
}

.risk-legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    color: var(--text-3);
    background: var(--glass);
    padding: 6px 16px;
    border: 1px solid var(--glass-border);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
}

.risk-legend-dot {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
}

/* Erasure Methods */
.erasure-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2px;
}

.erasure-card {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 36px;
    text-align: center;
    transition: var(--transition);
}

.erasure-card:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
}

.erasure-icon {
    width: 64px;
    height: 64px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
    transition: var(--transition);
}

.erasure-card:hover .erasure-icon {
    transform: scale(1.05);
}

.erasure-clear .erasure-icon { background: var(--blue-soft); color: var(--blue); border: 1px solid rgba(59,130,246,0.2); }
.erasure-purge .erasure-icon { background: var(--yellow-soft); color: var(--yellow); border: 1px solid rgba(234,179,8,0.2); }
.erasure-destroy .erasure-icon { background: var(--accent-soft); color: var(--accent); border: 1px solid rgba(255,45,45,0.2); }

.erasure-icon i { font-size: 1.3rem; }

.erasure-icon i svg {
    width: 28px;
    height: 28px;
}

.erasure-card h4 {
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.erasure-bar {
    height: 4px;
    background: var(--glass-strong);
    margin-bottom: 18px;
    overflow: hidden;
}

.erasure-clear .erasure-fill { background: var(--blue); }
.erasure-purge .erasure-fill { background: var(--yellow); }
.erasure-destroy .erasure-fill { background: var(--accent); }

.erasure-fill {
    height: 100%;
    transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.erasure-card p {
    font-size: 0.88rem;
    color: var(--text-3);
    margin-bottom: 16px;
    line-height: 1.7;
}

.erasure-card code {
    display: block;
    background: var(--bg);
    color: var(--green);
    padding: 12px 16px;
    font-family: var(--mono);
    font-size: 0.8rem;
    border: 1px solid var(--glass-border);
}

/* ============================================================
   AUTHOR PAGE
   ============================================================ */
.author-profile {
    display: flex;
    gap: 56px;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
}

.author-avatar {
    flex-shrink: 0;
}

.author-avatar i {
    font-size: 8rem;
    color: var(--accent);
}

.author-info h2 {
    font-size: 2.5rem;
    color: var(--text);
    margin-bottom: 8px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
}

.author-subtitle {
    color: var(--text-3);
    font-size: 0.95rem;
    margin-bottom: 28px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.author-details {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.author-detail {
    display: flex;
    gap: 16px;
    align-items: flex-start;
}

.author-detail i {
    color: var(--accent);
    font-size: 1.2rem;
    margin-top: 4px;
    flex-shrink: 0;
}

.author-detail strong {
    display: block;
    color: var(--text-muted);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 4px;
    font-weight: 700;
}

.author-detail p {
    color: var(--text-2);
    font-size: 0.95rem;
}

/* Avatar Placeholder */
.avatar-placeholder {
    width: 160px;
    height: 160px;
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 2px solid var(--accent);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: var(--transition);
}

.avatar-placeholder::after {
    display: none;
}

.avatar-placeholder:hover {
    background: var(--accent);
    transform: scale(1.03);
}

.avatar-initials {
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--accent);
    letter-spacing: 4px;
    transition: var(--transition);
}

.avatar-placeholder:hover .avatar-initials {
    color: var(--white);
}

/* Author Bio */
.author-bio {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-3);
    margin-bottom: 28px;
    padding: 24px;
    background: var(--glass);
    border-left: 4px solid var(--accent);
    border: 1px solid var(--glass-border);
    border-left: 4px solid var(--accent);
}

.author-bio a {
    color: var(--accent);
    font-weight: 700;
}

/* Author Contact Links */
.author-contact-links {
    display: flex;
    gap: 4px;
    margin-bottom: 36px;
    flex-wrap: wrap;
}

.contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-decoration: none;
    transition: var(--transition);
}

.contact-link:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--white);
    transform: translateY(-2px);
}

.contact-link i {
    font-size: 1rem;
}

.contact-link i svg {
    width: 16px;
    height: 16px;
}

/* Skills Grid */
.skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2px;
    margin-top: 36px;
}

.skill-category {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 32px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.skill-category::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: var(--accent);
    transition: width 0.4s ease;
}

.skill-category:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
}

.skill-category:hover::before {
    width: 100%;
}

.skill-icon {
    width: 56px;
    height: 56px;
    background: var(--accent-soft);
    border: 1px solid rgba(255, 45, 45, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: var(--transition);
}

.skill-category:hover .skill-icon {
    background: var(--accent);
    border-color: var(--accent);
}

.skill-category:hover .skill-icon i {
    color: var(--white);
}

.skill-icon i {
    font-size: 1.5rem;
    color: var(--accent);
    transition: var(--transition);
}

.skill-icon i svg {
    width: 28px;
    height: 28px;
}

.skill-category h4 {
    color: var(--text);
    font-size: 1rem;
    margin-bottom: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.skill-category ul {
    list-style: none;
}

.skill-category ul li {
    padding: 7px 0;
    color: var(--text-3);
    font-size: 0.88rem;
    padding-left: 22px;
    position: relative;
    transition: var(--transition);
}

.skill-category ul li:hover {
    color: var(--text);
    padding-left: 28px;
}

.skill-category ul li:before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 800;
    transition: var(--transition);
}

.skill-category ul li:hover::before {
    left: 4px;
}

/* Projects Grid */
.projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2px;
    margin-top: 36px;
}

.project-card {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 36px;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
}

.project-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: var(--accent);
    transition: width 0.4s ease;
}

.project-card:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
}

.project-card:hover::after {
    width: 100%;
}

.project-icon {
    width: 64px;
    height: 64px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: var(--transition);
}

.project-card:hover .project-icon {
    transform: scale(1.05);
}

.project-icon i {
    font-size: 1.8rem;
    color: var(--white);
}

.project-icon i svg {
    width: 32px;
    height: 32px;
}

.project-card h4 {
    color: var(--text);
    font-size: 1.15rem;
    margin-bottom: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.project-card p {
    color: var(--text-3);
    font-size: 0.88rem;
    line-height: 1.7;
    margin-bottom: 18px;
    flex-grow: 1;
}

.project-tech {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-bottom: 18px;
}

.tech-tag {
    display: inline-block;
    padding: 4px 14px;
    background: var(--glass-strong);
    color: var(--text-2);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid var(--glass-border);
}

.project-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--accent);
    font-weight: 800;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    transition: var(--transition);
    position: relative;
    z-index: 1;
}

.project-link:hover {
    color: var(--white);
    gap: 14px;
}

.project-link i {
    font-size: 0.85rem;
}

.project-link i svg {
    width: 14px;
    height: 14px;
}

/* Thesis Structure */
.thesis-structure {
    max-width: 800px;
    margin: 0 auto;
}

.structure-item {
    display: flex;
    gap: 24px;
    margin-bottom: 4px;
    align-items: flex-start;
    padding: 20px;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    transition: var(--transition);
}

.structure-item:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
}

.structure-num {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    background: var(--accent);
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 900;
    transition: var(--transition);
}

.structure-item:hover .structure-num {
    transform: scale(1.05);
}

.structure-content h4 {
    color: var(--text);
    margin-bottom: 8px;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
}

.structure-content p {
    font-size: 0.88rem;
    color: var(--text-3);
}

.structure-content ul {
    list-style: none;
}

.structure-content ul li {
    font-size: 0.85rem;
    color: var(--text-3);
    padding: 4px 0;
    padding-left: 18px;
    position: relative;
}

.structure-content ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 800;
}

/* Goals Grid */
.goals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2px;
}

.goal-card {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 36px;
    text-align: center;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.goal-card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.goal-card:hover {
    background: var(--glass-hover);
    border-color: var(--accent);
}

.goal-card:hover::before {
    transform: scaleX(1);
}

.goal-icon {
    width: 56px;
    height: 56px;
    background: var(--accent-soft);
    border: 1px solid rgba(255, 45, 45, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    transition: var(--transition);
}

.goal-card:hover .goal-icon {
    background: var(--accent);
    border-color: var(--accent);
}

.goal-card:hover .goal-icon i {
    color: var(--white);
}

.goal-icon i {
    font-size: 1.3rem;
    color: var(--accent);
    transition: var(--transition);
}

.goal-icon i svg {
    width: 26px;
    height: 26px;
}

.goal-card h4 {
    color: var(--text);
    margin-bottom: 12px;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
}

.goal-card p {
    font-size: 0.85rem;
    color: var(--text-3);
    line-height: 1.7;
}

/* References */
.references-list {
    max-width: 800px;
    margin: 0 auto;
}

.reference-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 16px 0;
    border-bottom: 1px solid var(--glass-border);
    transition: var(--transition);
}

.reference-item:hover {
    padding-left: 8px;
}

.reference-item:last-child {
    border-bottom: none;
}

.ref-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: var(--accent);
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 900;
}

.reference-item p {
    font-size: 0.88rem;
    color: var(--text-3);
}

/* ============================================================
   CONTACT PAGE
   ============================================================ */
.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
}

.contact-info-panel h3,
.contact-form-panel h3 {
    font-size: 1.3rem;
    color: var(--text);
    margin-bottom: 32px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.contact-info-panel h3 i,
.contact-form-panel h3 i {
    color: var(--accent);
    margin-right: 10px;
}

.contact-items {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 40px;
}

.contact-item {
    display: flex;
    gap: 16px;
    align-items: center;
    transition: var(--transition);
}

.contact-item:hover {
    transform: translateX(6px);
}

.contact-icon {
    width: 48px;
    height: 48px;
    background: var(--accent-soft);
    border: 1px solid rgba(255, 45, 45, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: var(--transition);
}

.contact-item:hover .contact-icon {
    background: var(--accent);
    border-color: var(--accent);
}

.contact-item:hover .contact-icon i {
    color: var(--white);
}

.contact-icon i {
    color: var(--accent);
    transition: var(--transition);
}

.contact-icon i svg {
    width: 20px;
    height: 20px;
}

.contact-item strong {
    display: block;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    font-weight: 700;
}

.contact-item p {
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 600;
}

.contact-topic {
    background: var(--glass);
    padding: 28px;
    border: 1px solid var(--glass-border);
    border-left: 4px solid var(--accent);
}

.contact-topic h4 {
    color: var(--text);
    margin-bottom: 12px;
    font-size: 0.95rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.contact-topic h4 i {
    color: var(--accent);
    margin-right: 8px;
}

.contact-topic p {
    font-size: 0.88rem;
    color: var(--text-3);
    line-height: 1.7;
}

/* Contact Form */
.contact-form-panel {
    background: var(--glass);
    backdrop-filter: var(--blur);
    -webkit-backdrop-filter: var(--blur);
    border: 1px solid var(--glass-border);
    border-radius: 0;
    padding: 40px;
}

.form-group {
    margin-bottom: 24px;
}

.form-group label {
    display: block;
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--text-3);
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.form-group label i {
    color: var(--accent);
    margin-right: 6px;
}

.form-group label i svg {
    width: 14px;
    height: 14px;
    vertical-align: -0.125em;
}

.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--glass-border);
    border-radius: 0;
    font-family: var(--font);
    font-size: 0.95rem;
    color: var(--text);
    transition: var(--transition);
    background: var(--surface);
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
    background: var(--glass);
}

.form-group input::placeholder,
.form-group textarea::placeholder {
    color: var(--text-muted);
}

.form-group textarea {
    resize: vertical;
}

.btn-submit {
    width: 100%;
    padding: 16px;
    font-size: 0.85rem;
}

.form-success {
    text-align: center;
    padding: 40px 20px;
}

.form-success i {
    font-size: 3rem;
    color: var(--green);
    margin-bottom: 16px;
}

.form-success p {
    font-size: 1rem;
    color: var(--text-2);
}

/* ============================================================
   FOOTER — Glass panel
   ============================================================ */
.footer {
    background: var(--bg-2);
    color: var(--text-3);
    padding: 80px 0 0;
    position: relative;
    border-top: 1px solid var(--glass-border);
}

.footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
}

.footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--glass-border);
}

.footer-col h4 {
    color: var(--text);
    margin-bottom: 24px;
    font-size: 0.85rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.footer-col h4 i {
    color: var(--accent);
    margin-right: 8px;
}

.footer-col h4 i svg {
    width: 18px;
    height: 18px;
    vertical-align: -0.15em;
}

.footer-col p {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--text-muted);
}

.footer-col ul {
    list-style: none;
}

.footer-col ul li {
    padding: 6px 0;
}

.footer-col ul li a {
    color: var(--text-muted);
    font-size: 0.88rem;
    transition: var(--transition);
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
}

.footer-col ul li a:hover {
    color: var(--accent);
    transform: translateX(6px);
}

.footer-bottom {
    padding: 28px 0;
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 992px) {
    .hero h1 {
        font-size: 2.5rem;
    }

    .hero-stats {
        flex-wrap: wrap;
    }

    .stat-item {
        flex: 1;
        min-width: 140px;
    }

    .intro-grid {
        grid-template-columns: 1fr;
    }

    .footer-grid {
        grid-template-columns: 1fr 1fr;
    }

    .contact-grid {
        grid-template-columns: 1fr;
    }

    .section {
        padding: 80px 0;
    }

    .section-title {
        font-size: 2.2rem;
    }
}

@media (max-width: 768px) {
    .nav-toggle {
        display: block;
    }

    .navbar {
        top: 0;
        width: 100%;
        border-radius: 0;
        border-left: none;
        border-right: none;
        border-top: none;
    }

    .nav-links {
        display: none;
        position: absolute;
        top: 64px;
        left: 0;
        right: 0;
        background: rgba(12, 12, 14, 0.95);
        backdrop-filter: var(--blur-heavy);
        -webkit-backdrop-filter: var(--blur-heavy);
        flex-direction: column;
        padding: 8px;
        border-bottom: 1px solid var(--glass-border);
    }

    .nav-links.active {
        display: flex;
    }

    .hero h1 {
        font-size: 2rem;
    }

    .hero-content {
        text-align: left;
    }

    .hero-stats {
        flex-direction: column;
        gap: 0;
    }

    .stat-item {
        border-right: 1px solid var(--glass-border);
        border-bottom: none;
    }

    .stat-item:last-child {
        border-right: 1px solid var(--glass-border);
    }

    .section {
        padding: 64px 0;
    }

    .section-title {
        font-size: 1.8rem;
    }

    .section-title::after {
        margin-bottom: 36px;
    }

    .timeline::before {
        left: 30px;
    }

    .timeline-marker {
        width: 60px;
        font-size: 0.7rem;
    }

    .devices-grid,
    .risks-grid,
    .cases-grid {
        grid-template-columns: 1fr;
    }

    .backup-visual {
        flex-direction: column;
        align-items: center;
        gap: 16px;
    }

    .footer-grid {
        grid-template-columns: 1fr;
    }

    .author-profile {
        flex-direction: column;
        text-align: center;
    }

    .author-contact-links {
        justify-content: center;
    }

    .fs-grid {
        grid-template-columns: 1fr 1fr;
    }

    .page-header {
        padding: 120px 24px 60px;
    }

    .page-header h1 {
        font-size: 2rem;
    }

    .back-to-top {
        bottom: 20px;
        right: 20px;
        width: 44px;
        height: 44px;
    }
}

@media (max-width: 480px) {
    .fs-grid,
    .encryption-grid,
    .erasure-methods,
    .goals-grid {
        grid-template-columns: 1fr;
    }

    .hero h1 {
        font-size: 1.6rem;
    }

    .navbar {
        padding: 0 16px;
    }

    .container {
        padding: 0 16px;
    }

    .hero-stats {
        margin-bottom: 40px;
    }
}

/* ============================================================
   ANIMATIONS
   ============================================================ */
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 1; transform: translateX(0); }
}

@keyframes fadeInRight {
    from { opacity: 0; transform: translateX(40px); }
    to { opacity: 1; transform: translateX(0); }
}

@keyframes scaleIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
}

.fade-in {
    animation: fadeInUp 0.7s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
}

.fade-in-left {
    animation: fadeInLeft 0.7s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
}

.fade-in-right {
    animation: fadeInRight 0.7s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
}

.scale-in {
    animation: scaleIn 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
}

.stagger-1 { animation-delay: 0.05s; }
.stagger-2 { animation-delay: 0.1s; }
.stagger-3 { animation-delay: 0.15s; }
.stagger-4 { animation-delay: 0.2s; }
.stagger-5 { animation-delay: 0.25s; }
.stagger-6 { animation-delay: 0.3s; }
.stagger-7 { animation-delay: 0.35s; }
.stagger-8 { animation-delay: 0.4s; }
.stagger-9 { animation-delay: 0.45s; }
.stagger-10 { animation-delay: 0.5s; }

/* ============================================================
   SCROLLBAR
   ============================================================ */
::-webkit-scrollbar {
    width: 8px;
}

::-webkit-scrollbar-track {
    background: var(--bg);
}

::-webkit-scrollbar-thumb {
    background: var(--glass-strong);
}

::-webkit-scrollbar-thumb:hover {
    background: var(--accent);
}

/* ============================================================
   ACCESSIBILITY
   ============================================================ */
:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
}

a:focus-visible {
    border-radius: 0;
}

@media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
    html {
        scroll-behavior: auto;
    }
}
