/* ===========================
   CSS Variables & Reset
   =========================== */
:root {
    --primary: #111827;
    --primary-dark: #000000;
    --primary-light: #f3f4f6;
    --primary-glow: rgba(0, 0, 0, 0.05);
    --secondary: #6b7280;
    --secondary-light: #f9fafb;
    --accent: #2563eb;
    --accent-light: #eff6ff;
    --warning: #d97706;
    --warning-light: #fef3c7;
    --dark: #111827;
    --dark-2: #1f2937;
    --dark-3: #374151;
    --gray-50: #ffffff;
    --gray-100: #f9fafb;
    --gray-200: #f3f4f6;
    --gray-300: #e5e7eb;
    --gray-400: #9ca3af;
    --gray-500: #6b7280;
    --gray-600: #4b5563;
    --gray-700: #374151;
    --gray-800: #1f2937;
    --gray-900: #111827;
    --white: #ffffff;
    --font-main: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    --shadow-xs: 0 1px 2px rgba(0,0,0,0.02);
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.03), 0 1px 2px rgba(0,0,0,0.02);
    --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.03), 0 2px 4px -2px rgba(0,0,0,0.02);
    --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.03), 0 4px 6px -4px rgba(0,0,0,0.02);
    --shadow-xl: 0 20px 25px -5px rgba(0,0,0,0.03), 0 8px 10px -6px rgba(0,0,0,0.02);
    --shadow-2xl: 0 25px 50px -12px rgba(0,0,0,0.05);
    --shadow-glow: 0 0 20px rgba(0, 0, 0, 0.02);
    --shadow-card-hover: 0 10px 30px -10px rgba(0, 0, 0, 0.05);
    --radius-sm: 4px;
    --radius-md: 6px;
    --radius-lg: 8px;
    --radius-xl: 12px;
    --radius-2xl: 16px;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-fast: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-spring: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    font-size: 16px;
}

body {
    font-family: var(--font-main);
    line-height: 1.7;
    color: var(--gray-700);
    background: var(--gray-50);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

a {
    color: var(--accent);
    text-decoration: none;
    transition: var(--transition);
}

a:hover {
    color: var(--dark);
}

img {
    max-width: 100%;
    height: auto;
}

::selection {
    background: var(--primary);
    color: var(--white);
}

/* ===========================
   Scroll Progress Bar
   =========================== */
.scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    background: var(--dark);
    background-size: 200% 100%;
    z-index: 10000;
    transition: width 0.1s linear;
    border-radius: 0 2px 2px 0;
}

@keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
}

/* ===========================
   Back to Top Button
   =========================== */
.back-to-top {
    position: fixed;
    bottom: 32px;
    right: 32px;
    width: 48px;
    height: 48px;
    background: var(--white);
    color: var(--dark);
    border: 1px solid var(--gray-200);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: var(--transition);
    z-index: 999;
    box-shadow: var(--shadow-sm);
}

.back-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}

.back-to-top:hover {
    background: var(--dark);
    color: var(--white);
    border-color: var(--dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.back-to-top svg {
    width: 20px;
    height: 20px;
}

/* ===========================
   Lucide Icons Global Styling
   =========================== */
svg[class*="lucide"] {
    width: 1em;
    height: 1em;
    stroke-width: 2;
    vertical-align: middle;
    display: inline-block;
    line-height: 1;
}

i[data-lucide] svg {
    vertical-align: -0.125em;
}

/* ===========================
   Container & Layout
   =========================== */
.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
}

.section {
    padding: 100px 0;
    position: relative;
}

.section-alt {
    background: var(--white);
}

.section-title {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 16px;
    text-align: center;
    position: relative;
    letter-spacing: -0.02em;
}

.section-title i {
    color: var(--accent);
    margin-right: 12px;
}

.section-title i svg {
    width: 32px;
    height: 32px;
    vertical-align: -0.2em;
}

.section-title::after {
    content: '';
    display: block;
    width: 48px;
    height: 2px;
    background: var(--gray-300);
    margin: 16px auto 48px;
    border-radius: 2px;
}

/* ===========================
   Navbar
   =========================== */
.navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    transition: var(--transition);
    border-bottom: 1px solid var(--gray-200);
}

.navbar.scrolled {
    background: rgba(255, 255, 255, 0.98);
    box-shadow: var(--shadow-sm);
    height: 60px;
}

.nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--dark);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
}

.nav-brand i {
    color: var(--primary);
    font-size: 1.4rem;
}

.nav-brand i svg {
    width: 24px;
    height: 24px;
}

.nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--dark);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 8px;
    border-radius: var(--radius-sm);
    transition: var(--transition-fast);
}

.nav-toggle:hover {
    background: var(--gray-100);
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 4px;
}

.nav-links a {
    color: var(--gray-600);
    padding: 10px 18px;
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: var(--transition-fast);
    position: relative;
}

.nav-links a i svg {
    width: 16px;
    height: 16px;
}

.nav-links a:hover {
    color: var(--dark);
    background: var(--gray-100);
}

.nav-links a.active {
    color: var(--white);
    background: var(--primary);
    box-shadow: none;
}

/* ===========================
   Hero Section
   =========================== */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-50);
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 0%, var(--gray-100) 0%, transparent 70%);
}

.hero-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(var(--gray-200) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.5;
}

/* Floating orbs - simplified for clean look */
.hero-orb {
    display: none;
}

.hero-content {
    position: relative;
    text-align: center;
    padding: 40px 24px;
    max-width: 920px;
    z-index: 2;
}

.hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 20px;
    line-height: 1.15;
    letter-spacing: -0.03em;
}

.hero h1 i {
    color: var(--accent);
}

.hero-subtitle {
    font-size: 1.25rem;
    color: var(--gray-500);
    margin-bottom: 48px;
    font-weight: 400;
    letter-spacing: 0.01em;
}

.hero-stats {
    display: flex;
    justify-content: center;
    gap: 56px;
    margin-bottom: 48px;
}

.stat-item {
    text-align: center;
    position: relative;
}

.stat-item::after {
    content: '';
    position: absolute;
    right: -28px;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 40px;
    background: var(--gray-200);
}

.stat-item:last-child::after {
    display: none;
}

.stat-number {
    display: block;
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--dark);
    line-height: 1;
}

.stat-label {
    display: block;
    font-size: 0.82rem;
    color: var(--gray-500);
    margin-top: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
}

.hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--dark);
    color: var(--white);
    padding: 16px 36px;
    border-radius: 100px;
    font-size: 1rem;
    font-weight: 600;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.hero-btn::before {
    display: none;
}

.hero-btn:hover::before {
    display: none;
}

.hero-btn i svg {
    width: 20px;
    height: 20px;
    transition: var(--transition);
}

.hero-btn:hover {
    background: var(--gray-700);
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.hero-btn:hover i svg {
    animation: bounceDown 0.6s ease infinite;
}

@keyframes bounceDown {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
}

/* ===========================
   Page Header (non-index)
   =========================== */
.page-header {
    background: var(--gray-50);
    padding: 130px 24px 70px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--gray-200);
}

.page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 50% 100%, var(--gray-100) 0%, transparent 60%);
}

.page-header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    position: relative;
}

.page-header h1 i {
    color: var(--accent);
    margin-right: 12px;
}

.page-header p {
    font-size: 1.1rem;
    color: var(--gray-500);
    position: relative;
    font-weight: 400;
}

/* ===========================
   Introduction Section
   =========================== */
.intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: start;
}

.intro-text p {
    margin-bottom: 20px;
    font-size: 1.05rem;
    color: var(--gray-600);
    line-height: 1.8;
}

.intro-highlights {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.highlight-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-left: 3px solid var(--gray-300);
    padding: 24px 28px;
    border-radius: var(--radius-md);
    transition: var(--transition);
    position: relative;
}

.highlight-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    background: transparent;
    opacity: 0;
    transition: var(--transition);
}

.highlight-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateX(4px);
    border-left-color: var(--accent);
}

.highlight-card:hover::after {
    opacity: 1;
}

.highlight-card i {
    color: var(--dark);
    font-size: 1.3rem;
    margin-bottom: 8px;
}

.highlight-card i svg {
    width: 32px;
    height: 32px;
}

.highlight-card h4 {
    color: var(--dark);
    margin-bottom: 6px;
    font-weight: 700;
}

.highlight-card p {
    font-size: 0.9rem;
    color: var(--gray-500);
    position: relative;
    z-index: 1;
}

/* ===========================
   Timeline
   =========================== */
.timeline {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 50px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--gray-200);
    border-radius: 2px;
}

.timeline-item {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 24px;
    position: relative;
}

.timeline-marker {
    flex-shrink: 0;
    width: 100px;
    height: 38px;
    background: var(--dark);
    color: var(--white);
    border-radius: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.82rem;
    font-weight: 700;
    z-index: 1;
    box-shadow: none;
    letter-spacing: 0.5px;
}

.timeline-content {
    background: var(--white);
    border: 1px solid var(--gray-200);
    padding: 24px 28px;
    border-radius: var(--radius-md);
    flex: 1;
    transition: var(--transition);
    position: relative;
}

.timeline-content::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gray-300);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    opacity: 0;
    transition: var(--transition);
}

.timeline-content:hover {
    box-shadow: var(--shadow-lg);
    transform: translateX(4px);
}

.timeline-content:hover::before {
    opacity: 1;
}

.timeline-content h4 {
    color: var(--dark);
    margin-bottom: 8px;
    font-weight: 700;
}

.timeline-content h4 i {
    color: var(--primary);
    margin-right: 8px;
}

.timeline-content h4 i svg {
    width: 20px;
    height: 20px;
    vertical-align: -0.15em;
}

.timeline-content p {
    font-size: 0.92rem;
    color: var(--gray-500);
    line-height: 1.6;
}

/* ===========================
   Device Cards
   =========================== */
.devices-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 24px;
}

.device-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 32px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.device-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gray-300);
    transition: var(--transition);
}

.device-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: transparent;
    opacity: 0;
    transition: var(--transition);
    pointer-events: none;
}

.device-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
    border-color: var(--gray-300);
}

.device-card:hover::after {
    opacity: 1;
}

.device-card:hover::before {
    height: 5px;
}

.device-icon {
    width: 60px;
    height: 60px;
    background: var(--gray-100);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: var(--transition);
}

.device-card:hover .device-icon {
    transform: scale(1.05);
    box-shadow: none;
}

.device-icon i {
    font-size: 1.5rem;
    color: var(--dark);
}

.device-icon i svg {
    width: 28px;
    height: 28px;
}

.device-card h3 {
    font-size: 1.3rem;
    color: var(--dark);
    margin-bottom: 16px;
    font-weight: 700;
}

.device-specs {
    margin-bottom: 16px;
}

.spec {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid var(--gray-100);
    font-size: 0.9rem;
    transition: var(--transition-fast);
}

.spec:hover {
    padding-left: 4px;
    background: var(--gray-50);
    margin: 0 -4px;
    padding-right: 4px;
    border-radius: 4px;
}

.spec-label {
    color: var(--gray-500);
    font-weight: 600;
}

.device-desc {
    font-size: 0.9rem;
    color: var(--gray-500);
    margin-bottom: 16px;
    line-height: 1.6;
}

.device-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.tag {
    padding: 5px 14px;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.3px;
}

.tag-green {
    background: var(--secondary-light);
    color: #065f46;
}

.tag-yellow {
    background: var(--warning-light);
    color: #92400e;
}

.tag-red {
    background: var(--accent-light);
    color: #9f1239;
}

/* ===========================
   Data Table
   =========================== */
.interfaces-table-wrapper,
.table-responsive {
    overflow-x: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--gray-200);
}

.data-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--white);
    font-size: 0.92rem;
}

.data-table thead {
    background: var(--gray-100);
    color: var(--dark);
}

.data-table th {
    padding: 16px 20px;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--gray-200);
}

.data-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--gray-100);
    transition: var(--transition-fast);
}

.data-table tbody tr {
    transition: var(--transition-fast);
}

.data-table tbody tr:hover {
    background: var(--primary-light);
}

.data-table tbody tr:last-child td {
    border-bottom: none;
}

.data-table td i {
    color: var(--primary);
    margin-right: 8px;
}

.table-check {
    color: var(--secondary) !important;
}

.table-cross {
    color: var(--accent) !important;
}

.table-partial {
    color: var(--warning) !important;
}

/* ===========================
   File Systems Section
   =========================== */
.fs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.fs-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: 28px 24px;
    text-align: center;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.fs-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gray-300);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.fs-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
}

.fs-card:hover::before {
    transform: scaleX(1);
}

.fs-card h4 {
    font-size: 1.25rem;
    color: var(--dark);
    margin-bottom: 14px;
    font-weight: 800;
}

.fs-bar {
    height: 6px;
    background: var(--gray-200);
    border-radius: 3px;
    margin-bottom: 16px;
    overflow: hidden;
}

.fs-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--warning), var(--secondary));
    border-radius: 3px;
    font-size: 0;
    transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.fs-card ul {
    list-style: none;
    text-align: left;
    margin-bottom: 14px;
}

.fs-card ul li {
    font-size: 0.85rem;
    color: var(--gray-500);
    padding: 4px 0;
    border-bottom: 1px dotted var(--gray-200);
}

.fs-card ul li:last-child {
    border-bottom: none;
}

.fs-verdict {
    display: inline-block;
    padding: 5px 16px;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.3px;
}

.verdict-good {
    background: var(--secondary-light);
    color: #065f46;
}

.verdict-warning {
    background: var(--warning-light);
    color: #92400e;
}

/* ===========================
   Risk Cards
   =========================== */
.risks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 20px;
}

.risk-card {
    background: var(--white);
    border-radius: var(--radius-md);
    padding: 28px;
    position: relative;
    overflow: hidden;
    transition: var(--transition);
    border: 1px solid var(--gray-200);
}

.risk-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
}

.risk-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    transition: height 0.3s ease;
}

.risk-card:hover::before {
    height: 5px;
}

.risk-critical::before { background: linear-gradient(90deg, var(--accent), #fb7185); }
.risk-high::before { background: linear-gradient(90deg, #ea580c, #f97316); }
.risk-medium::before { background: linear-gradient(90deg, var(--warning), #fbbf24); }
.risk-low::before { background: linear-gradient(90deg, var(--secondary), #34d399); }

.risk-level {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    margin-bottom: 12px;
}

.risk-critical .risk-level { background: var(--accent-light); color: #9f1239; }
.risk-high .risk-level { background: #fff7ed; color: #c2410c; }
.risk-medium .risk-level { background: var(--warning-light); color: #92400e; }
.risk-low .risk-level { background: var(--secondary-light); color: #065f46; }

.risk-card h4 {
    color: var(--dark);
    margin-bottom: 10px;
    font-size: 1.05rem;
    font-weight: 700;
}

.risk-card h4 i {
    margin-right: 8px;
    color: var(--primary);
}

.risk-card h4 i svg {
    width: 18px;
    height: 18px;
    vertical-align: -0.15em;
}

.risk-card p {
    font-size: 0.9rem;
    color: var(--gray-500);
    margin-bottom: 14px;
    line-height: 1.6;
}

.risk-meta {
    display: flex;
    gap: 20px;
    font-size: 0.82rem;
    color: var(--gray-400);
    padding-top: 12px;
    border-top: 1px solid var(--gray-100);
}

/* ===========================
   Protection Section
   =========================== */
.protection-block {
    margin-bottom: 72px;
}

.protection-block h3 {
    font-size: 1.5rem;
    color: var(--dark);
    margin-bottom: 28px;
    font-weight: 800;
}

.protection-block h3 i {
    color: var(--primary);
    margin-right: 10px;
}

.encryption-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
}

.encrypt-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: 32px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.encrypt-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 0;
    background: var(--gray-400);
    transition: height 0.4s ease;
}

.encrypt-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
}

.encrypt-card:hover::after {
    height: 100%;
}

.encrypt-logo {
    width: 52px;
    height: 52px;
    background: var(--gray-100);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: var(--transition);
}

.encrypt-card:hover .encrypt-logo {
    transform: scale(1.05);
}

.encrypt-logo i {
    font-size: 1.3rem;
    color: var(--dark);
}

.encrypt-logo i svg {
    width: 24px;
    height: 24px;
}

.encrypt-card h4 {
    color: var(--dark);
    margin-bottom: 14px;
    font-weight: 700;
}

.encrypt-card ul {
    list-style: none;
}

.encrypt-card ul li {
    font-size: 0.9rem;
    color: var(--gray-500);
    padding: 5px 0;
    padding-left: 22px;
    position: relative;
    line-height: 1.5;
}

.encrypt-card ul li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--secondary);
    font-weight: 800;
}

/* Backup Visual */
.backup-visual {
    display: flex;
    justify-content: center;
    gap: 48px;
    margin-bottom: 36px;
}

.backup-rule {
    text-align: center;
}

.backup-number {
    width: 88px;
    height: 88px;
    background: var(--dark);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.4rem;
    font-weight: 800;
    margin: 0 auto 12px;
    box-shadow: none;
    transition: var(--transition);
    position: relative;
}

.backup-number::after {
    display: none;
}

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.backup-rule:hover .backup-number {
    transform: scale(1.05);
    box-shadow: var(--shadow-md);
}

.backup-rule p {
    font-size: 0.92rem;
    color: var(--gray-600);
    font-weight: 600;
}

.backup-types {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.backup-type {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: 24px;
    transition: var(--transition);
}

.backup-type:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.backup-type h5 {
    color: var(--dark);
    margin-bottom: 8px;
    font-weight: 700;
}

.backup-type h5 i {
    color: var(--primary);
    margin-right: 8px;
}

.backup-type h5 i svg {
    width: 18px;
    height: 18px;
    vertical-align: -0.125em;
}

.backup-type p {
    font-size: 0.88rem;
    color: var(--gray-500);
    line-height: 1.6;
}

/* ===========================
   Checklist
   =========================== */
.checklist {
    max-width: 800px;
    margin: 0 auto;
}

.checklist-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 24px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    margin-bottom: 10px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.checklist-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--primary);
    transform: scaleY(0);
    transition: transform 0.3s ease;
}

.checklist-item:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--gray-300);
    transform: translateX(4px);
}

.checklist-item:hover::before {
    transform: scaleY(1);
}

.check-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: var(--primary-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
}

.checklist-item:hover .check-icon {
    background: var(--primary);
}

.checklist-item:hover .check-icon i {
    color: var(--white);
}

.check-icon i {
    color: var(--primary);
    font-size: 0.85rem;
    transition: var(--transition-fast);
}

.check-icon i svg {
    width: 18px;
    height: 18px;
}

.check-content {
    flex: 1;
    font-size: 0.92rem;
}

.check-content strong {
    color: var(--dark);
    font-weight: 700;
}

.nist-badge {
    flex-shrink: 0;
    padding: 5px 12px;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 1.5px;
}

.badge-identify { background: #dbeafe; color: #1e40af; }
.badge-protect { background: var(--secondary-light); color: #065f46; }
.badge-detect { background: var(--warning-light); color: #92400e; }
.badge-respond { background: var(--accent-light); color: #9f1239; }
.badge-recover { background: #f3e8ff; color: #6b21a8; }

/* ===========================
   Case Studies
   =========================== */
.cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
}

.case-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--gray-200);
    transition: var(--transition);
}

.case-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
}

.case-header {
    padding: 24px 28px;
    color: var(--white);
    position: relative;
    overflow: hidden;
}

.case-header::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
}

.case-danger { background: linear-gradient(135deg, #991b1b, #dc2626); }
.case-warning { background: linear-gradient(135deg, #c2410c, #ea580c); }
.case-success { background: linear-gradient(135deg, #166534, #16a34a); }

.case-year {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    padding: 3px 14px;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 800;
    margin-bottom: 8px;
    backdrop-filter: blur(4px);
}

.case-header h4 {
    font-size: 1.1rem;
    font-weight: 700;
    position: relative;
    z-index: 1;
}

.case-body {
    padding: 28px;
}

.case-body p {
    font-size: 0.92rem;
    color: var(--gray-500);
    margin-bottom: 16px;
    line-height: 1.7;
}

.case-lesson {
    background: var(--gray-50);
    padding: 14px 18px;
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    color: var(--gray-600);
    border-left: 3px solid var(--gray-300);
    line-height: 1.6;
}

/* ===========================
   CTA Section
   =========================== */
.cta-section {
    background: var(--gray-50);
    text-align: center;
    padding: 80px 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--gray-200);
    border-bottom: 1px solid var(--gray-200);
}

.cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, var(--gray-100), transparent 70%);
}

.cta-content {
    position: relative;
    z-index: 1;
}

.cta-content h2 {
    font-size: 2.2rem;
    color: var(--dark);
    margin-bottom: 14px;
    font-weight: 800;
    letter-spacing: -0.02em;
}

.cta-content h2 i {
    color: var(--accent);
}

.cta-content h2 i svg {
    width: 32px;
    height: 32px;
    vertical-align: -0.2em;
}

.cta-content p {
    color: var(--gray-500);
    margin-bottom: 28px;
    font-size: 1.05rem;
}

.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--dark);
    color: var(--white);
    padding: 14px 32px;
    border-radius: 100px;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.btn-primary::before {
    display: none;
}

.btn-primary:hover::before {
    display: none;
}

.btn-primary:hover {
    background: var(--gray-700);
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

/* ===========================
   Charts Page
   =========================== */
.chart-wrapper {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 32px;
    max-width: 900px;
    margin: 0 auto;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
}

.chart-wrapper:hover {
    box-shadow: var(--shadow-md);
}

.chart-wrapper-sm {
    max-width: 700px;
}

.chart-description {
    text-align: center;
    color: var(--gray-500);
    max-width: 700px;
    margin: -20px auto 28px;
    font-size: 0.95rem;
    line-height: 1.6;
}

/* Risk Legend */
.risk-legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 24px;
}

.risk-legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--gray-500);
    background: var(--white);
    padding: 6px 14px;
    border-radius: 100px;
    border: 1px solid var(--gray-200);
}

.risk-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
}

/* Erasure Methods */
.erasure-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
}

.erasure-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 32px;
    text-align: center;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.erasure-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
}

.erasure-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    transition: var(--transition);
}

.erasure-card:hover .erasure-icon {
    transform: scale(1.1);
}

.erasure-clear .erasure-icon { background: #dbeafe; color: #1e40af; }
.erasure-purge .erasure-icon { background: var(--warning-light); color: #92400e; }
.erasure-destroy .erasure-icon { background: var(--accent-light); color: #9f1239; }

.erasure-icon i { font-size: 1.3rem; }

.erasure-icon i svg {
    width: 28px;
    height: 28px;
}

.erasure-card h4 {
    color: var(--dark);
    margin-bottom: 14px;
    font-weight: 700;
}

.erasure-bar {
    height: 6px;
    background: var(--gray-200);
    border-radius: 3px;
    margin-bottom: 16px;
    overflow: hidden;
}

.erasure-clear .erasure-fill { background: linear-gradient(90deg, var(--gray-400), var(--gray-500)); }
.erasure-purge .erasure-fill { background: linear-gradient(90deg, var(--warning), #fbbf24); }
.erasure-destroy .erasure-fill { background: linear-gradient(90deg, var(--accent), #fb7185); }

.erasure-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.erasure-card p {
    font-size: 0.9rem;
    color: var(--gray-500);
    margin-bottom: 14px;
    line-height: 1.6;
}

.erasure-card code {
    display: block;
    background: var(--dark);
    color: #34d399;
    padding: 10px 16px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    border: 1px solid var(--dark-3);
}

/* ===========================
   Author Page
   =========================== */
.author-profile {
    display: flex;
    gap: 48px;
    align-items: center;
    max-width: 800px;
    margin: 0 auto;
}

.author-avatar {
    flex-shrink: 0;
}

.author-avatar i {
    font-size: 8rem;
    color: var(--primary);
}

.author-info h2 {
    font-size: 2.2rem;
    color: var(--dark);
    margin-bottom: 6px;
    font-weight: 900;
    letter-spacing: -0.02em;
}

.author-subtitle {
    color: var(--gray-400);
    font-size: 1.05rem;
    margin-bottom: 24px;
    font-weight: 500;
}

.author-details {
    display: flex;
    flex-direction: column;
    gap: 18px;
}

.author-detail {
    display: flex;
    gap: 16px;
    align-items: flex-start;
}

.author-detail i {
    color: var(--primary);
    font-size: 1.2rem;
    margin-top: 4px;
    flex-shrink: 0;
}

.author-detail strong {
    display: block;
    color: var(--gray-400);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 2px;
    font-weight: 700;
}

.author-detail p {
    color: var(--gray-600);
    font-size: 0.95rem;
}

/* Author Avatar Placeholder */
.avatar-placeholder {
    width: 160px;
    height: 160px;
    background: var(--dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: none;
    position: relative;
    transition: var(--transition);
}

.avatar-placeholder::after {
    display: none;
}

.avatar-placeholder:hover {
    transform: scale(1.05);
}

.avatar-initials {
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--white);
    letter-spacing: 3px;
}

/* Author Bio */
.author-bio {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--gray-500);
    margin-bottom: 24px;
    padding: 20px 24px;
    background: var(--gray-50);
    border-left: 3px solid var(--gray-300);
    border-radius: var(--radius-sm);
}

/* Author Contact Links */
.author-contact-links {
    display: flex;
    gap: 12px;
    margin-bottom: 32px;
    flex-wrap: wrap;
}

.contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: var(--white);
    border: 2px solid var(--gray-200);
    border-radius: 100px;
    color: var(--dark);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
    transition: var(--transition);
}

.contact-link:hover {
    border-color: var(--dark);
    color: var(--dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    background: var(--gray-100);
}

.contact-link i {
    font-size: 1.1rem;
}

.contact-link i svg {
    width: 18px;
    height: 18px;
}

/* Skills Grid */
.skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
    margin-top: 32px;
}

.skill-category {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.skill-category::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gray-300);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.skill-category:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-6px);
}

.skill-category:hover::before {
    transform: scaleX(1);
}

.skill-icon {
    width: 64px;
    height: 64px;
    background: var(--gray-100);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: var(--transition);
    box-shadow: none;
}

.skill-category:hover .skill-icon {
    transform: scale(1.05);
}

.skill-icon i {
    font-size: 1.8rem;
    color: var(--dark);
}

.skill-icon i svg {
    width: 32px;
    height: 32px;
}

.skill-category h4 {
    color: var(--dark);
    font-size: 1.1rem;
    margin-bottom: 14px;
    font-weight: 700;
}

.skill-category ul {
    list-style: none;
}

.skill-category ul li {
    padding: 7px 0;
    color: var(--gray-500);
    font-size: 0.92rem;
    padding-left: 22px;
    position: relative;
    transition: var(--transition-fast);
}

.skill-category ul li:hover {
    color: var(--gray-700);
    padding-left: 26px;
}

.skill-category ul li:before {
    content: '\25B8';
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: bold;
    transition: var(--transition-fast);
}

.skill-category ul li:hover::before {
    left: 4px;
}

/* Projects Grid */
.projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 28px;
    margin-top: 32px;
}

.project-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 32px;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
}

.project-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 0;
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.01));
    transition: height 0.4s ease;
}

.project-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
    border-color: var(--gray-300);
}

.project-card:hover::after {
    height: 100%;
}

.project-icon {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: var(--transition);
    box-shadow: var(--shadow-md);
}

.project-card:hover .project-icon {
    transform: scale(1.08) rotate(3deg);
}

.project-icon i {
    font-size: 2rem;
    color: var(--white);
}

.project-icon i svg {
    width: 36px;
    height: 36px;
}

.project-card h4 {
    color: var(--dark);
    font-size: 1.25rem;
    margin-bottom: 12px;
    font-weight: 800;
}

.project-card p {
    color: var(--gray-500);
    font-size: 0.92rem;
    line-height: 1.7;
    margin-bottom: 16px;
    flex-grow: 1;
}

.project-tech {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
}

.tech-tag {
    display: inline-block;
    padding: 4px 14px;
    background: var(--gray-100);
    color: var(--gray-600);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 100px;
    border: 1px solid var(--gray-200);
}

.project-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--dark);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: var(--transition);
    position: relative;
    z-index: 1;
}

.project-link:hover {
    color: var(--primary-dark);
    gap: 14px;
}

.project-link i {
    font-size: 0.85rem;
}

.project-link i svg {
    width: 14px;
    height: 14px;
}

/* Thesis Structure */
.thesis-structure {
    max-width: 800px;
    margin: 0 auto;
}

.structure-item {
    display: flex;
    gap: 24px;
    margin-bottom: 28px;
    align-items: flex-start;
}

.structure-num {
    flex-shrink: 0;
    width: 54px;
    height: 54px;
    background: var(--dark);
    color: var(--white);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    box-shadow: none;
    transition: var(--transition);
}

.structure-item:hover .structure-num {
    transform: scale(1.08);
}

.structure-content h4 {
    color: var(--dark);
    margin-bottom: 8px;
    font-weight: 700;
}

.structure-content p {
    font-size: 0.92rem;
    color: var(--gray-500);
}

.structure-content ul {
    list-style: none;
}

.structure-content ul li {
    font-size: 0.9rem;
    color: var(--gray-500);
    padding: 4px 0;
    padding-left: 18px;
    position: relative;
}

.structure-content ul li::before {
    content: '\203A';
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: 700;
    font-size: 1.1rem;
}

/* Goals Grid */
.goals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
}

.goal-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 32px;
    text-align: center;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.goal-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gray-300);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.goal-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
}

.goal-card:hover::before {
    transform: scaleX(1);
}

.goal-icon {
    width: 60px;
    height: 60px;
    background: var(--gray-100);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    transition: var(--transition);
}

.goal-card:hover .goal-icon {
    transform: scale(1.05);
    background: var(--dark);
    box-shadow: none;
}

.goal-card:hover .goal-icon i {
    color: var(--white);
}

.goal-icon i {
    font-size: 1.3rem;
    color: var(--dark);
    transition: var(--transition-fast);
}

.goal-icon i svg {
    width: 28px;
    height: 28px;
}

.goal-card h4 {
    color: var(--dark);
    margin-bottom: 10px;
    font-weight: 700;
}

.goal-card p {
    font-size: 0.88rem;
    color: var(--gray-500);
    line-height: 1.6;
}

/* References */
.references-list {
    max-width: 800px;
    margin: 0 auto;
}

.reference-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 14px 0;
    border-bottom: 1px solid var(--gray-200);
    transition: var(--transition-fast);
}

.reference-item:hover {
    padding-left: 8px;
}

.reference-item:last-child {
    border-bottom: none;
}

.ref-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: var(--gray-200);
    color: var(--dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    font-weight: 700;
}

.reference-item p {
    font-size: 0.92rem;
    color: var(--gray-500);
}

/* ===========================
   Contact Page
   =========================== */
.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
}

.contact-info-panel h3,
.contact-form-panel h3 {
    font-size: 1.4rem;
    color: var(--dark);
    margin-bottom: 28px;
    font-weight: 800;
}

.contact-info-panel h3 i,
.contact-form-panel h3 i {
    color: var(--primary);
    margin-right: 10px;
}

.contact-items {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 36px;
}

.contact-item {
    display: flex;
    gap: 16px;
    align-items: center;
    transition: var(--transition-fast);
}

.contact-item:hover {
    transform: translateX(4px);
}

.contact-icon {
    width: 48px;
    height: 48px;
    background: var(--primary-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: var(--transition);
}

.contact-item:hover .contact-icon {
    background: var(--primary);
}

.contact-item:hover .contact-icon i {
    color: var(--white);
}

.contact-icon i {
    color: var(--primary);
    transition: var(--transition-fast);
}

.contact-icon i svg {
    width: 20px;
    height: 20px;
}

.contact-item strong {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--gray-400);
    font-weight: 700;
}

.contact-item p {
    color: var(--dark);
    font-size: 0.95rem;
    font-weight: 500;
}

.contact-topic {
    background: var(--gray-50);
    padding: 24px 28px;
    border-radius: var(--radius-md);
    border-left: 3px solid var(--gray-300);
}

.contact-topic h4 {
    color: var(--dark);
    margin-bottom: 10px;
    font-size: 1rem;
    font-weight: 700;
}

.contact-topic h4 i {
    color: var(--primary);
    margin-right: 8px;
}

.contact-topic p {
    font-size: 0.9rem;
    color: var(--gray-500);
    line-height: 1.6;
}

/* Contact Form */
.contact-form-panel {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 36px;
    box-shadow: var(--shadow-md);
}

.form-group {
    margin-bottom: 24px;
}

.form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--gray-600);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.form-group label i {
    color: var(--primary);
    margin-right: 6px;
}

.form-group label i svg {
    width: 16px;
    height: 16px;
    vertical-align: -0.125em;
}

.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid var(--gray-200);
    border-radius: var(--radius-sm);
    font-family: var(--font-main);
    font-size: 0.95rem;
    color: var(--gray-800);
    transition: var(--transition);
    background: var(--gray-50);
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.06);
    background: var(--white);
}

.form-group input::placeholder,
.form-group textarea::placeholder {
    color: var(--gray-400);
}

.form-group textarea {
    resize: vertical;
}

.btn-submit {
    width: 100%;
    padding: 14px;
    font-size: 1rem;
}

.form-success {
    text-align: center;
    padding: 40px 20px;
}

.form-success i {
    font-size: 3rem;
    color: var(--secondary);
    margin-bottom: 16px;
}

.form-success p {
    font-size: 1.05rem;
    color: var(--gray-600);
}

/* ===========================
   Footer
   =========================== */
.footer {
    background: var(--gray-100);
    color: var(--gray-600);
    padding: 72px 0 0;
    position: relative;
    border-top: 1px solid var(--gray-200);
}

.footer::before {
    display: none;
}

.footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--gray-200);
}

.footer-col h4 {
    color: var(--dark);
    margin-bottom: 20px;
    font-size: 1.05rem;
    font-weight: 700;
}

.footer-col h4 i {
    color: var(--primary);
    margin-right: 8px;
}

.footer-col h4 i svg {
    width: 20px;
    height: 20px;
    vertical-align: -0.15em;
}

.footer-col p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--gray-500);
}

.footer-col ul {
    list-style: none;
}

.footer-col ul li {
    padding: 5px 0;
}

.footer-col ul li a {
    color: var(--gray-500);
    font-size: 0.9rem;
    transition: var(--transition-fast);
    display: inline-block;
}

.footer-col ul li a:hover {
    color: var(--dark);
    transform: translateX(4px);
}

.footer-bottom {
    padding: 24px 0;
    text-align: center;
    font-size: 0.85rem;
    color: var(--gray-400);
}

/* ===========================
   Responsive
   =========================== */
@media (max-width: 992px) {
    .hero h1 {
        font-size: 2.5rem;
    }

    .hero-stats {
        gap: 32px;
    }

    .intro-grid {
        grid-template-columns: 1fr;
    }

    .footer-grid {
        grid-template-columns: 1fr 1fr;
    }

    .contact-grid {
        grid-template-columns: 1fr;
    }

    .section {
        padding: 72px 0;
    }
}

@media (max-width: 768px) {
    .nav-toggle {
        display: block;
    }

    .nav-links {
        display: none;
        position: absolute;
        top: 68px;
        left: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        flex-direction: column;
        padding: 16px;
        box-shadow: var(--shadow-lg);
        border-top: 1px solid var(--gray-200);
    }

    .nav-links.active {
        display: flex;
    }

    .hero h1 {
        font-size: 2rem;
    }

    .hero-stats {
        flex-direction: column;
        gap: 20px;
    }

    .stat-item::after {
        display: none;
    }

    .stat-number {
        font-size: 2.5rem;
    }

    .section {
        padding: 56px 0;
    }

    .section-title {
        font-size: 1.6rem;
    }

    .section-title::after {
        margin-bottom: 32px;
    }

    .timeline::before {
        left: 30px;
    }

    .timeline-marker {
        width: 60px;
        font-size: 0.72rem;
    }

    .devices-grid {
        grid-template-columns: 1fr;
    }

    .risks-grid {
        grid-template-columns: 1fr;
    }

    .cases-grid {
        grid-template-columns: 1fr;
    }

    .backup-visual {
        flex-direction: column;
        gap: 24px;
    }

    .footer-grid {
        grid-template-columns: 1fr;
    }

    .author-profile {
        flex-direction: column;
        text-align: center;
    }

    .author-contact-links {
        justify-content: center;
    }

    .fs-grid {
        grid-template-columns: 1fr 1fr;
    }

    .page-header {
        padding: 110px 24px 50px;
    }

    .page-header h1 {
        font-size: 2rem;
    }

    .back-to-top {
        bottom: 20px;
        right: 20px;
        width: 44px;
        height: 44px;
    }
}

@media (max-width: 480px) {
    .fs-grid {
        grid-template-columns: 1fr;
    }

    .encryption-grid {
        grid-template-columns: 1fr;
    }

    .erasure-methods {
        grid-template-columns: 1fr;
    }

    .goals-grid {
        grid-template-columns: 1fr;
    }

    .hero h1 {
        font-size: 1.6rem;
    }

    .navbar {
        padding: 0 16px;
    }

    .container {
        padding: 0 16px;
    }
}

/* ===========================
   Animations
   =========================== */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(40px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeInLeft {
    from {
        opacity: 0;
        transform: translateX(-40px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

@keyframes fadeInRight {
    from {
        opacity: 0;
        transform: translateX(40px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

@keyframes scaleIn {
    from {
        opacity: 0;
        transform: scale(0.9);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

.fade-in {
    animation: fadeInUp 0.7s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
}

.fade-in-left {
    animation: fadeInLeft 0.7s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
}

.fade-in-right {
    animation: fadeInRight 0.7s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
}

.scale-in {
    animation: scaleIn 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
}

.stagger-1 { animation-delay: 0.05s; }
.stagger-2 { animation-delay: 0.1s; }
.stagger-3 { animation-delay: 0.15s; }
.stagger-4 { animation-delay: 0.2s; }
.stagger-5 { animation-delay: 0.25s; }
.stagger-6 { animation-delay: 0.3s; }
.stagger-7 { animation-delay: 0.35s; }
.stagger-8 { animation-delay: 0.4s; }
.stagger-9 { animation-delay: 0.45s; }
.stagger-10 { animation-delay: 0.5s; }

/* ===========================
   Scrollbar
   =========================== */
::-webkit-scrollbar {
    width: 8px;
}

::-webkit-scrollbar-track {
    background: var(--gray-100);
}

::-webkit-scrollbar-thumb {
    background: var(--gray-300);
    border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
    background: var(--gray-400);
}

/* ===========================
   Focus & Accessibility
   =========================== */
:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
}

a:focus-visible {
    border-radius: 4px;
}

@media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }

    html {
        scroll-behavior: auto;
    }
}
